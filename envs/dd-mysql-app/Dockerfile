# dd-mysql-app — Domino compute environment for a MySQL "database app"
#
# Paste into Domino's "Dockerfile Instructions" field. Base image: Domino
# Standard Environment (Ubuntu 22.04 / Py 3.10). Do NOT add a FROM line.
#
# Process model when this image runs as a Domino App:
#   :8888  Flask router (dbapp/router.py) — only externally-bound port
#   :8978  Apache + phpMyAdmin (admin UI, internal — fronted at /admin/)
#   :3306  mysqld (internal only)
#
# Each RUN is one line — Domino's UI eats `\` continuations across pipes.
# USER root at the top — the DSE base image runs as a non-root user.

USER root

# MySQL 8.0 server + client from Ubuntu's universe repo. Originally
# planned to use Oracle's repo (repo.mysql.com), but Oracle's
# Release-engineering key B7B3B788A8D3785C has expired AND they haven't
# re-signed the jammy InRelease with a current key — even fetching
# RPM-GPG-KEY-mysql-2023 doesn't help because the InRelease is still
# 2022-signed. Ubuntu universe ships the same upstream MySQL 8.0.x
# (currently 8.0.43+), Canonical-signed and stable. Same `mysqld` and
# `mysql` binaries.
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends gnupg lsb-release ca-certificates curl wget cron sudo mysql-server mysql-client && rm -rf /var/lib/apt/lists/*

# Apache + PHP 8.1 (mod_php) + phpMyAdmin. We use Apache rather than the
# PHP built-in server so URL rewriting + /admin/ prefix routing work the
# same way pgweb's --prefix=admin works for Postgres.
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends apache2 libapache2-mod-php php-cli php-mysql php-mbstring php-zip php-gd php-json php-curl phpmyadmin && a2enmod rewrite proxy_fcgi setenvif && a2dismod mpm_event mpm_worker || true && a2enmod mpm_prefork && rm -rf /var/lib/apt/lists/*

# Python deps for Flask router + snapshotter.
RUN pip install --no-cache-dir 'flask>=3.0' 'flask-sock>=0.7' 'flask-cors>=4.0' 'gunicorn>=21.2' 'requests>=2.31' 'websockets==12.0' 'httpx==0.27.0'

# Bake dbapp/ + snapshotter/ from this repo. Pulled from main.
ARG GITHUB_TOKEN=
RUN mkdir -p /opt/dd && ( set -e; if [ -n "$GITHUB_TOKEN" ]; then curl -fsSL -H "Authorization: Bearer $GITHUB_TOKEN" https://codeload.github.com/ddl-nick-goble/Database-Extension/tar.gz/refs/heads/main -o /tmp/dd-src.tar.gz; else curl -fsSL https://codeload.github.com/ddl-nick-goble/Database-Extension/tar.gz/refs/heads/main -o /tmp/dd-src.tar.gz; fi && tar -xzf /tmp/dd-src.tar.gz -C /tmp && cp -r /tmp/Database-Extension-main/dbapp /opt/dd/dbapp && cp -r /tmp/Database-Extension-main/snapshotter /opt/dd/snapshotter && cp /tmp/Database-Extension-main/dbapp/app.sh /opt/dd/app.sh && chmod +x /opt/dd/app.sh && rm -rf /tmp/dd-src.tar.gz /tmp/Database-Extension-main ) || echo "[dd] WARN: could not bake dbapp/ from GitHub at build time (private repo without GITHUB_TOKEN, or no network). Image is still valid: DB Apps in THIS project run from /mnt/code/dbapp. For cross-project drop-in, rebuild with --build-arg GITHUB_TOKEN=<pat> or make the repo public."

# Apache config for the /admin/ admin UI. Listens on 8978, serves
# phpMyAdmin at /admin/. The DocumentRoot is the alias target so direct
# requests to / land at phpMyAdmin too (harmless — only /admin/ is
# reachable via the public router).
RUN mkdir -p /etc/dd && printf '%s\n' 'ServerRoot "/etc/apache2"' 'PidFile /tmp/apache2.pid' 'Mutex file:/tmp default' 'ServerName localhost' 'Listen 8978' 'User ubuntu' 'Group ubuntu' 'ErrorLog /var/log/dd/apache2.err' 'CustomLog /var/log/dd/apache2.log combined' 'LogLevel warn' 'Timeout 60' 'KeepAlive On' 'MaxKeepAliveRequests 100' 'KeepAliveTimeout 5' 'HostnameLookups Off' 'IncludeOptional /etc/apache2/mods-enabled/*.load' 'IncludeOptional /etc/apache2/mods-enabled/*.conf' 'AccessFileName .htaccess' '<FilesMatch "^\\.ht">' '  Require all denied' '</FilesMatch>' 'DirectoryIndex index.php index.html' 'Alias /admin /usr/share/phpmyadmin' 'Alias /admin/ /usr/share/phpmyadmin/' '<Directory /usr/share/phpmyadmin>' '  Options FollowSymLinks' '  AllowOverride All' '  Require all granted' '</Directory>' 'DocumentRoot /usr/share/phpmyadmin' > /etc/dd/apache2.conf

# phpMyAdmin config. Reads MySQL creds from env at request time via
# getenv() — the MySQL adapter exports DD_MYSQL_HOST/PORT/USER/PASSWORD
# when it launches Apache. Pre-connected (auth_type=config) — Domino's
# app proxy is the only auth gate.
RUN printf '%s\n' '<?php' '/* Generated by dd-mysql-app — pre-connects to the in-pod mysqld */' '$cfg["blowfish_secret"] = "domino-databases-not-a-secret-just-for-cookies";' '$cfg["PmaAbsoluteUri"] = "/admin/";' '$cfg["SendErrorReports"] = "never";' '$cfg["ShowHint"] = false;' '$cfg["CheckConfigurationPermissions"] = false;' '$i = 1;' '$cfg["Servers"][$i]["host"] = getenv("DD_MYSQL_HOST") ?: "127.0.0.1";' '$cfg["Servers"][$i]["port"] = getenv("DD_MYSQL_PORT") ?: "3306";' '$cfg["Servers"][$i]["auth_type"] = "config";' '$cfg["Servers"][$i]["user"] = getenv("DD_MYSQL_USER") ?: "domino";' '$cfg["Servers"][$i]["password"] = getenv("DD_MYSQL_PASSWORD") ?: "";' '$cfg["Servers"][$i]["AllowNoPassword"] = false;' '$cfg["Servers"][$i]["compress"] = false;' '$cfg["Servers"][$i]["extension"] = "mysqli";' '$cfg["TempDir"] = "/tmp/phpmyadmin";' > /etc/phpmyadmin/config.inc.php && mkdir -p /tmp/phpmyadmin && chown -R ubuntu:ubuntu /tmp/phpmyadmin /etc/phpmyadmin

RUN mkdir -p /mnt/db /mnt/db/sock /var/log/dd && chown -R ubuntu:ubuntu /mnt/db /var/log/dd /opt/dd && chown -R ubuntu:ubuntu /var/lib/apache2 /var/log/apache2 /var/lock 2>/dev/null || true

ENV DD_ROLE=mysql DD_ENGINE=mysql DD_OPT_DIR=/opt/dd

USER ubuntu
